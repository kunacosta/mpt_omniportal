import 'dart:convert';
import 'package:http/http.dart' as http;

class ApiService {
  // Use 10.0.2.2 for Android Emulator, or your machine's IP for physical devices
  static const String baseUrl = 'http://10.0.2.2:8000';

  /// Handles Login
  Future<Map<String, dynamic>> login(String username, String password) async {
    final response = await http.post(
      Uri.parse('$baseUrl/api/login'),
      headers: {'Content-Type': 'application/json'},
      body: jsonEncode({
        'username': username,
        'password': password,
      }),
    );

    if (response.statusCode == 200) {
      return jsonDecode(response.body);
    } else {
      final error = jsonDecode(response.body);
      throw Exception(error['detail'] ?? 'Failed to login');
    }
  }

  /// Fetches Dashboard Summary and Stats
  Future<DashboardData> getDashboardSummary() async {
    final response = await http.get(Uri.parse('$baseUrl/api/summary'));

    if (response.statusCode == 200) {
      return DashboardData.fromJson(jsonDecode(response.body));
    } else {
      throw Exception('Failed to load dashboard data');
    }
  }
}

/// Data Models for Dashboard
class DashboardData {
  final double totalNetworkRevenue;
  final double totalInvestment;
  final List<Outlet> outlets;

  DashboardData({
    required this.totalNetworkRevenue,
    required this.totalInvestment,
    required this.outlets,
  });

  factory DashboardData.fromJson(Map<String, dynamic> json) {
    return DashboardData(
      totalNetworkRevenue: (json['totalNetworkRevenue'] as num).toDouble(),
      totalInvestment: (json['totalInvestment'] as num).toDouble(),
      outlets: (json['outlets'] as List)
          .map((i) => Outlet.fromJson(i))
          .toList(),
    );
  }
}

class Outlet {
  final String name;
  final double totalRevenue;
  final double totalInvestment;
  final int transactionCount;
  final Map<String, double> brands; // Branch performance by brand
  final List<SalesmanProfile> salesmanProfiles;

  Outlet({
    required this.name,
    required this.totalRevenue,
    required this.totalInvestment,
    required this.transactionCount,
    required this.brands,
    required this.salesmanProfiles,
  });

  factory Outlet.fromJson(Map<String, dynamic> json) {
    var brandMap = Map<String, double>.from(json['brands'].map(
      (key, value) => MapEntry(key, (value as num).toDouble()),
    ));

    var profiles = (json['salesmanProfiles'] as Map<String, dynamic>).values
        .map((p) => SalesmanProfile.fromJson(p))
        .toList();

    // Sort salesman by revenue for Sales Ranking
    profiles.sort((a, b) => b.totalRevenue.compareTo(a.totalRevenue));

    return Outlet(
      name: json['name'],
      totalRevenue: (json['totalRevenue'] as num).toDouble(),
      totalInvestment: (json['totalInvestment'] as num).toDouble(),
      transactionCount: json['transactionCount'],
      brands: brandMap,
      salesmanProfiles: profiles,
    );
  }
}

class SalesmanProfile {
  final String name;
  final double totalRevenue;
  final int transactionCount;

  SalesmanProfile({
    required this.name,
    required this.totalRevenue,
    required this.transactionCount,
  });

  factory SalesmanProfile.fromJson(Map<String, dynamic> json) {
    return SalesmanProfile(
      name: json['name'],
      totalRevenue: (json['totalRevenue'] as num).toDouble(),
      transactionCount: json['transactionCount'],
    );
  }
}